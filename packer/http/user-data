#cloud-config
autoinstall:
  version: 1
  locale: en_US.UTF-8
  keyboard:
    layout: en
  identity:
    hostname: vagrant
    password: "$6$rounds=4096$vagrant$bRYBVmqMmHFCZ7N7GjZJZt5YjLGQJQGvXqN5Y5L3KQDh5N5Y5L3KQDh5N5Y5L3KQDh5N5Y5L3KQDh5N5"
